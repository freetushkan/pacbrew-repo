pkgname=ps5-payload-libmodplug
pkgver=0.8.9.0
pkgrel=0
pkgdesc='A MOD playing library'
arch=('any')
url='http://modplug-xmms.sourceforge.net'
license=('LicenseRef-PublicDomain')
source=("https://downloads.sourceforge.net/modplug-xmms/libmodplug-${pkgver}.tar.gz")
sha256sums=('457ca5a6c179656d66c01505c0d95fafaead4329b9dbaa0f997d00a3508ad9de')
options=(!strip libtool staticlibs)
groups=('ps5-payload-dev')
makedepends=('ps5-payload-sdk' 'ps5-payload-libcxx')

prepare() {
    if [ -z "${PS5_PAYLOAD_SDK}" ]; then
	export PS5_PAYLOAD_SDK=/opt/ps5-payload-sdk
    fi

    cd libmodplug-$pkgver
    sed -i 's|-ffast-math||g' configure.ac
    sed -i 's|-lstdc++|-lc++|g' libmodplug.pc.in
    autoreconf -vfi
}

build() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd libmodplug-$pkgver

    ./configure --prefix="${PREFIX}" --host=x86_64-pc-freebsd \
		--enable-static --disable-shared \
		CXXFLAGS=-std=c++11
    ${MAKE}
}

package() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd libmodplug-$pkgver

    export DESTDIR="${pkgdir}/${DESTDIR}"
    ${MAKE} install

  ${PS5_CROSS_FIX_ROOT} "${DESTDIR}/${PREFIX}"
}
